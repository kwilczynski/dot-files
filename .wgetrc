continue = on
check-certificate = on
robots = off
timeout = 60
progress = bar
timestamping = on
no_parent = on
tries = 3
retry_connrefused = on
trust_server_names = off
follow_ftp = on
adjust_extension = off
server_response = on
user_agent = Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36
hsts-file = /dev/null
