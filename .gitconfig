[includeIf "gitdir:~/Projects/Personal/"]
  path = ~/.gitconfig-personal

[includeIf "gitdir:~/Development/Projects/Personal/"]
  path = ~/.gitconfig-personal

[includeIf "hasconfig:remote.*.url:ssh://git@gitolite.kernel.org/**"]
  path = ~/.gitconfig-linux

[includeIf "hasconfig:remote.*.url:*://git.kernel.org/**"]
  path = ~/.gitconfig-linux

[includeIf "gitdir:~/Projects/Work/"]
  path = ~/.gitconfig-work

[includeIf "gitdir:~/Development/Projects/Work/"]
  path = ~/.gitconfig-work

[includeIf "hasconfig:remote.*.url:git@github.com*/**"]
  path = ~/.gitconfig-push

[alias]
  a = add
  au = add -u .
  ap = add -p
  ay = apply
  ame = amend
  ami = am -i
  ama = am --abort
  b = branch
  bl = blame
  br = branch -v
  bra = branch -a
  brd = branch-date
  brc = branch --contains
  brm = branch --merged
  brnm = branch --no-merged
  ci = commit
  cl = clean
  clf = clean --force
  clfd = clean --force -d
  clo = clone
  clor = clone --recursive
  co = checkout
  conflicts = diff --name-only --diff-filter=U
  sh = show
  sh1 = show -1
  sh2 = show -2
  shm = !sh -c 'git show $(git origin)..HEAD'
  sb = show-branch
  lo = log
  lf = log --follow
  ll = log --graph --pretty='format:%h [%an] %s'
  loa = log --graph --oneline --all --decorate --simplify-by-decoration
  lot = log --graph --oneline --all --decorate --topo-order
  los = log --graph --oneline --abbrev-commit
  lof = log --format=fuller
  lom = !sh -c 'git log $(git origin)..HEAD "$@"' -
  lop = log --first-parent --oneline
  llog = log --pretty=format:'%C(yellow)%h %Cred%ad %Cblue%an%Cgreen%d %Creset%s' --date=iso
  ls = ls-files
  st = status
  stu = status --untracked=no
  stb = status -sb
  s = status -s
  su = status -s --untracked=no
  sn = status -sb --untracked=no
  bi = bisect
  bis = bisect start
  bir = bisect reset
  big = bisect good
  bib = bisect bad
  cep = cherry-pick
  cepa = cherry-pick --abort
  cepc = cherry-pick --continue
  df = diff
  dfp = diff --diff-algorithm=patience
  dfc = diff --cached
  dfcs = diff --compact-summary
  dfr = diff --relative
  dfs = diff --staged
  dft = diff --stat
  dfn = diff --name-only
  dftt = diff-tree
  dfns = diff --name-status
  dfw = diff -w
  dfm = !sh -c 'git diff $(git name-rev --name-only $(git origin))'
  df1 = diff HEAD~
  df2 = diff HEAD~~
  df3 = diff HEAD~~~
  df4 = diff HEAD~~~~
  df5 = diff HEAD~~~~~
  wdc = diff --color-words --cached
  rb = rebase
  rba = rebase --abort
  rbc = rebase --continue
  rbi = rebase --interactive
  rbik = rebase --interactive --keep-base
  rbm = !sh -c 'git rebase --interactive $(git origin) "$@"' -
  rbr = rebase --root
  rbs = rebase --skip
  rd = range-diff
  me = merge
  rs = remote show
  remotes = remote -v
  f = fetch
  fe = fetch
  fea = fetch --all
  pu = pull
  pur = pull --rebase
  pup = pull --prune
  purp = pull --prune --rebase
  puo = !sh -c 'git pull upstream $(git origin)'
  pus = !sh -c 'git submodule foreach git pull origin $(git origin)'
  purs = pull --recurse-submodules
  pull-all = pull --recurse-submodules -r
  pt = push --tags
  t = tag
  tags = tag -l
  w = log --raw
  wo = log --raw --oneline
  wn = log --raw --name-only --oneline
  wno = log --raw --pretty='format:' --name-only
  sts = status -s
  rl = reflog
  ref = reflog
  r = reset
  rh = reset --hard
  rr = restore
  rrs = restore --staged
  rt = remote
  se = send-email
  sl = shortlog
  sm = submodule
  sta = stash
  stal = stash list
  stap = stash pop
  stad = stash drop
  staa = stash push --include-untracked
  sms = submodule status
  smi = submodule init
  smu = submodule update
  smf = submodule foreach
  rup = remote update
  rpr = remote prune
  cia = commit -a
  com = !sh -c 'git checkout $(git origin)'
  cob = checkout -b
  cod = checkout develop
  sw = switch
  swc = switch -c
  detach = checkout HEAD^0
  info = config --list
  summary = log --oneline
  rank = shortlog -sn --no-merges
  tree = log --graph --oneline --decorate
  fp = format-patch
  fp1 = format-patch -1
  fpm = !sh -c 'git format-patch $(git origin)..HEAD "$@"' -
  po = push origin
  poh = push -u origin HEAD
  pf = push --force-with-lease
  pom = !sh -c 'git push origin $(git origin) "$@"' -
  changelog = log --pretty=format:'%Cgreen%d %Creset%s' --date=iso
  pob = !sh -c 'git push origin $(git branch -l 2> /dev/null | sed -e \"/^[^*]/d\" -e \"s/* \\(.*\\)/\\1/\") "$@"' -
  pobf = !sh -c 'git push origin $(git branch --show-current) --force-with-lease "$@"' -
  purb = !sh -c 'git pull origin $(git branch -l 2> /dev/null | sed -e \"/^[^*]/d\" -e \"s/* \\(.*\\)/\\1/\") --rebase "$@"' -
  amend = commit --amend --reuse-message=HEAD
  amende = commit --amend
  last = log --oneline -10
  review = log --stat=160,180 -p -w --patience --reverse -M -C -C -c
  undo = reset HEAD^ --mixed
  undoc = reset --soft HEAD^
  unstage = reset HEAD --
  nuke = !sh -c 'git reset --hard HEAD && git clean -fd'
  serve = !git daemon --base-path=. --export-all --reuseaddr --informative-errors --verbose
  hub = !git daemon --base-path=. --export-all --enable=receive-pack --reuseaddr --informative-errors --verbose
  this = !git init && git add . && git commit -m \"Initial commit.\"
  empty = !git init && git commit --allow-empty -m \"Initial commit.\"
  rmd = !git ls-files -z --deleted | xargs -0 git rm
  wd = !git diff | delta --features='default no-line-numbers' --true-color='always' --color-only | less -FRSX
  update-author = !sh -c 'git rebase --onto $1 --exec \"git commit --amend --author=$2\" $1' --
  origin = !git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@'
  branch-date = !git for-each-ref --sort='-committerdate:iso8601' --format='%(committerdate:iso8601)|%(committerdate:relative)|%(committername)|%(refname:short)' refs/heads/ | column -s '|' -t
  tag-date = !git for-each-ref --sort='-taggerdate' --format='%(taggerdate:iso8601)|%(taggerdate:relative)|%(taggername)|%(tag)|%(subject)' refs/tags/ | column -s '|' -t
  root = !git rev-parse --show-toplevel
  reref = rerere forget
  rerefc = !sh -c 'rm -Rf "$(git root)/.git/rr-cache"'
  mt = mergetool
  vc = verify-commit
  wa = worktree add
  wl = worktree list --verbose
  wr = worktree remove
  wp = worktree prune --verbose

[advice]
  mergeConflict = false
  skippedCherryPicks = false
  addEmptyPathspec = false
  addIgnoredFile = false

[delta]
  tabs = 0
  keep-plus-minus-markers = true
  inspect-raw-lines = false
  features = default
  true-color = always

[delta "default"]
  dark = true
  syntax-theme = zenburn
  line-numbers = true

[delta "no-line-numbers"]
  line-numbers = false

[color]
  branch = auto
  diff = auto
  status = auto
  interactive = auto
  ui = true
  pager = true

[pack]
  threads = 0
  useBitmapBoundaryTraversal = true
  allowPackReuse = multi

[rename]
  limit = 0

[status]
  compareBranches = @{upstream} @{push}

[checkout]
  workers = 0

[commit]
  verbose = true

[merge]
  tool = meld
  renameLimit = 0
  conflictstyle = zdiff3
  log = true

[mergetool]
  prompt = false

[mergetool "meld"]
  cmd = meld "$LOCAL" "$MERGED" "$REMOTE" --output "$MERGED"

[diff]
  algorithm = histogram
  renames = copies
  submodule = diff
  mnemonicprefix = true
  colorMoved = dimmed_zebra

[log]
  date = local

[core]
  excludesfile = ~/.gitignore-global
  pager = delta --true-color='always'
  autocrlf = input
  quotePath = false
  longPaths = true
  untrackedCache = true

[gc]
  auto = 0
  autoDetach = false
  prune = false
  logExpiry = never
  reflogExpire = never
  reflogExpireUnreachable = never
  worktreePruneExpire = never
  pruneExpire = never

[maintenance]
  auto = false
  autoDetach = false
  strategy = none

[trailer]
  ifexists = addIfDifferent

[interactive]
  diffFilter = delta --color-only

[rerere]
  enabled = true
  autoupdate = true

[init]
  templatedir = ~/.git-templates
  defaultBranch = main

[credential]
  helper = cache --timeout=3600

[credential "https://github.com"]
  username = kwilczynski

[gpg]
  program = gpg

[push]
  default = current
  followTags = true

[pull]
  rebase = true

[fetch]
  prune = true
  writeCommitGraph = true

[rebase]
  autosquash = true

[tag]
  sort = version:refname
  forceSignAnnotated = true

[branch]
  autosetuprebase = always

[remote "origin"]
  followRemoteHead = always

[url "git@github.com:"]
  insteadOf = gh:
  insteadOf = https://github.com/
  pushInsteadOf = github:
  pushInsteadOf = git://github.com/

[url "https://github.com/"]
  insteadOf = github:

[url "git@gist.github.com:"]
  insteadOf = gst:
  pushInsteadOf = gist:
  pushInsteadOf = git://gist.github.com/

[url "https://gist.github.com/"]
  insteadOf = gist:
